# ──────────────────────────────────────────────────────────────────────────────
# .env.cloudflare.example — template para docker-compose.cloudflare.yml
#
# Domínio registrado: z3ndocs.uk (Cloudflare Registrar)
#
# Como obter o CLOUDFLARE_TUNNEL_TOKEN:
#   1. Acesse https://one.dash.cloudflare.com
#   2. Zero Trust → Networks → Tunnels → Create a tunnel
#   3. Tipo: Cloudflared → nome: docagent → Next
#   4. Copie o token exibido (começa com eyJ...)
#   5. Configure as public hostnames:
#      - z3ndocs.uk            → http://frontend:80  (a SPA + proxy da API)
#      - evolution.z3ndocs.uk  → http://evolution-api:8080  (opcional)
# ──────────────────────────────────────────────────────────────────────────────

# Domínio principal (sem https://)
DOMAIN=z3ndocs.uk

# Token do Cloudflare Tunnel (obtido no passo acima)
CLOUDFLARE_TUNNEL_TOKEN=eyJ...cole-aqui-o-token-completo

# Segurança — gere com: openssl rand -hex 32
SECRET_KEY=troque-por-uma-chave-aleatoria-de-64-chars

# Admin padrão
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=troque-esta-senha

# PostgreSQL (DocAgent)
POSTGRES_USER=docagent
POSTGRES_PASSWORD=senha-segura-aqui
POSTGRES_DB=docagent

# PostgreSQL (Evolution API)
POSTGRES_EVOLUTION_USER=evolution
POSTGRES_EVOLUTION_PASSWORD=senha-segura-aqui

# Evolution API
EVOLUTION_API_KEY=chave-api-evolution-segura

# Ollama rodando no host
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# LangSmith (opcional)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=docagent
