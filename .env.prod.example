# Domínio principal
DOMAIN=seudominio.com
ACME_EMAIL=seu@email.com

# Segurança
SECRET_KEY=troque-por-uma-chave-aleatoria-de-64-chars
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$...  # htpasswd format (gere com: htpasswd -nb admin senha)

# Admin padrão
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=troque-esta-senha

# PostgreSQL (DocAgent)
POSTGRES_USER=docagent
POSTGRES_PASSWORD=senha-segura-aqui
POSTGRES_DB=docagent

# PostgreSQL (Evolution API)
POSTGRES_EVOLUTION_USER=evolution
POSTGRES_EVOLUTION_PASSWORD=senha-segura-aqui

# Evolution API
EVOLUTION_API_KEY=chave-api-evolution-segura

# Ollama (pode ser host ou URL remota)
OLLAMA_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text
