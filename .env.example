# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PATH=./data/chroma_db

# Memoria (opcional — valores padrao)
SUMMARY_THRESHOLD=6
RECENT_MESSAGES_TO_KEEP=2

# LangSmith (opcional — deixe em branco para desativar o tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=docagent
