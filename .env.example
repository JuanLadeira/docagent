# Ollama
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=qwen2.5:7b
EMBED_MODEL=nomic-embed-text

# ChromaDB
CHROMA_PATH=./data/chroma_db

# Memoria (opcional — valores padrao)
SUMMARY_THRESHOLD=6
RECENT_MESSAGES_TO_KEEP=2

# LangSmith (opcional — deixe em branco para desativar o tracing)
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=docagent

# HuggingFace Local com TurboQuant KV cache compression (provider hf_local)
# Instalar dependências: uv sync --extra hf
# ATENÇÃO: rodar uvicorn com --workers 1 — singleton de modelo não é compartilhado entre processos
LLM_HF_MODEL=Qwen/Qwen2.5-7B-Instruct
TURBOQUANT_ENABLED=true
TURBOQUANT_BITS=3
TURBOQUANT_DEVICE=cuda
